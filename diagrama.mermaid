```mermaid
erDiagram
    auth_users ||--|| profiles : "1:1"
    profiles ||--o{ lotes : "crea"
    profiles ||--o{ productos : "crea"
    profiles ||--o{ ordenes_solicitante : "solicita"
    profiles ||--o{ ordenes_proveedor : "provee"
    profiles ||--o{ calificaciones_calificador : "califica"
    profiles ||--o{ calificaciones_calificado : "recibe"
    profiles ||--o{ guias : "autor"
    profiles ||--o{ guias_guardadas : "guarda"
    profiles ||--o{ notificaciones : "recibe"
    profiles ||--o{ orden_mensajes : "envia"
    profiles ||--o{ auditoria_admin : "ejecuta"
    
    lotes ||--o{ ordenes : "referenciado_en"
    productos ||--o{ ordenes : "referenciado_en"
    ordenes ||--|| calificaciones : "genera"
    ordenes ||--o{ orden_mensajes : "contiene"
    ordenes ||--o{ notificaciones : "genera"
    
    tipos_residuo ||--o{ lotes : "categoriza"
    lotes ||--o{ lotes_historial : "trackea"
    guias ||--o{ guias_guardadas : "guardada_por"

    profiles {
        uuid id PK
        text email UK
