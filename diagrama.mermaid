        numeric ubicacion_lat
        numeric ubicacion_lng
        text direccion
        date fecha_disponible
        date fecha_vencimiento
        batch_status estado
        text status
        text[] imagenes
        text admin_notes
        timestamp deleted_at
        timestamp created_at
        timestamp updated_at
    }

    productos {
        uuid id PK
        uuid user_id FK
        text nombre
        text descripcion
        text[] imagenes
        text origen_roa
        text[] categoria_tipo
        text[] categoria_funcionalidad
        integer precio_unidad
        boolean incluye_domicilio
        integer costo_domicilio
        text direccion_vendedor
        boolean disponible
        text status
        timestamp created_at
        timestamp updated_at
    }

    ordenes {
        uuid id PK
        uuid solicitante_id FK
        uuid proveedor_id FK
        uuid item_id FK
        item_type tipo_item
        order_status estado
        numeric cantidad_solicitada
        date fecha_propuesta_retiro
        time hora_propuesta_retiro
        text modalidad_entrega
        text direccion_contacto
        text telefono_contacto
        text mensaje_solicitud
        text mensaje_respuesta
        timestamp created_at
        timestamp updated_at
    }

    calificaciones {
        uuid id PK
        uuid orden_id FK
        uuid calificador_id FK
        uuid calificado_id FK
        uuid producto_id FK
        integer puntuacion
        text comentario
        boolean reportada
        boolean oculta
        timestamp created_at
        timestamp updated_at
    }

    tipos_residuo {
        uuid id PK
        text nombre UK
        text descripcion
        boolean activo
        timestamp created_at
        timestamp updated_at
    }

    guias {
        uuid id PK
        uuid autor_id FK
        text titulo
        text descripcion
        text contenido
        text tipo
        text categoria
        text nivel
        text portada_url
