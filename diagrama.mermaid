        timestamp created_at
        timestamp updated_at
    }

    guias_guardadas {
        uuid id PK
        uuid user_id FK
        uuid guia_id FK
        timestamp created_at
    }

    notificaciones {
        uuid id PK
        uuid user_id FK
        uuid orden_id FK
        uuid entity_id FK
        text entity_type
        text tipo
        text titulo
        text mensaje
        text redirect_url
        jsonb metadata
